// Arshin Kids — Prisma 7 schema (PrismaPg adapter + Neon Postgres).
// CLAUDE.md §1: DB is unreachable from local Iran — DO NOT run `prisma migrate`
// or `db push`. Apply DDL by hand in the Neon SQL console (see prisma/init.sql),
// keep this file in sync, then `npx prisma generate` locally (offline-safe).

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Admin CMS users (hand-rolled JWT auth — CLAUDE.md §5).
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  createdAt    DateTime @default(now())

  @@map("admin_users")
}

/// Enrollment / contact leads from the public form.
model Lead {
  id             String     @id @default(cuid())
  parentName     String
  phone          String
  childName      String?
  childBirthYear Int? // Persian (Jalali) birth year, e.g. 1400
  program        String? // free text or program slug
  message        String?
  service        String     @default("enroll") // discriminator: enroll | contact
  status         LeadStatus @default(NEW)
  createdAt      DateTime   @default(now())
  readAt         DateTime?

  @@index([status, createdAt])
  @@map("leads")
}

enum LeadStatus {
  NEW
  READ
  CONTACTED
  ARCHIVED
}

/// Programs / classes offered (age groups, services).
model Program {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  summary     String // short card text
  description String? // long body (page)
  ageRange    String? // e.g. "۳ تا ۴ سال"
  color       String   @default("accent") // token name for the card accent
  icon        String? // lucide icon name
  imageUrl    String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([published, order])
  @@map("programs")
}

/// Staff / teachers.
model StaffMember {
  id        String   @id @default(cuid())
  name      String
  role      String // e.g. "مدیر" / "مربی"
  bio       String?
  photoUrl  String?
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([published, order])
  @@map("staff")
}

/// Photo gallery images (Vercel Blob URLs).
model GalleryImage {
  id        String   @id @default(cuid())
  url       String
  caption   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  @@index([order])
  @@map("gallery")
}

/// News / announcements (blog-style).
model Post {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  excerpt     String?
  content     String // markdown / HTML
  coverUrl    String?
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
  @@map("posts")
}

/// Frequently asked questions (also feeds FAQPage JSON-LD).
model Faq {
  id        String  @id @default(cuid())
  question  String
  answer    String
  order     Int     @default(0)
  published Boolean @default(true)

  @@index([published, order])
  @@map("faqs")
}

/// Video courses — lessons hosted on Aparat (we store the video hash + embed).
/// `accessType` splits the public /courses page into free vs purchasable.
model Course {
  id          String     @id @default(cuid())
  slug        String     @unique
  title       String
  summary     String // short card text
  description String? // long body (landing page)
  coverUrl    String?
  accessType  AccessType @default(FREE)
  price       Int? // Toman; null for free courses
  published   Boolean    @default(false)
  order       Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  sections    CourseSection[]
  lessons     Lesson[]
  orders      Order[]
  enrollments Enrollment[]

  @@index([published, order])
  @@map("courses")
}

enum AccessType {
  FREE
  PAID
}

/// Optional grouping of lessons within a course (e.g. "فصل اول").
model CourseSection {
  id       String @id @default(cuid())
  courseId String
  course   Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title    String
  order    Int    @default(0)

  lessons Lesson[]

  @@index([courseId, order])
  @@map("course_sections")
}

/// A single video lesson (Aparat-hosted).
model Lesson {
  id            String         @id @default(cuid())
  courseId      String
  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  sectionId     String?
  section       CourseSection? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  title         String
  aparatHash    String // Aparat video hash, parsed from the pasted link
  durationSec   Int?
  isFreePreview Boolean        @default(false) // free sample inside a PAID course
  order         Int            @default(0)
  createdAt     DateTime       @default(now())

  @@index([courseId, order])
  @@map("lessons")
}

/// End-customer accounts (separate from AdminUser). Email+password now;
/// phone+OTP later (Phase C). CLAUDE.md §5.
model Customer {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  phone        String?  @unique
  createdAt    DateTime @default(now())

  orders      Order[]
  enrollments Enrollment[]

  @@map("customers")
}

/// A purchase attempt for a course (Zarinpal).
model Order {
  id         String      @id @default(cuid())
  customerId String
  customer   Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course      @relation(fields: [courseId], references: [id], onDelete: Cascade)
  amount     Int // Toman
  status     OrderStatus @default(PENDING)
  authority  String?     @unique // Zarinpal authority token
  refId      String? // Zarinpal reference id (on success)
  createdAt  DateTime    @default(now())
  paidAt     DateTime?

  enrollment Enrollment?

  @@index([customerId, createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

/// Access grant: a customer owns a course (created on verified payment).
model Enrollment {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  courseId   String
  course     Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  orderId    String?  @unique
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())

  @@unique([customerId, courseId])
  @@index([customerId])
  @@map("enrollments")
}
