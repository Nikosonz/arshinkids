# Copy to .env.local for local dev. Set the real values in the Vercel dashboard.
# CLAUDE.md §1: DB/Google are unreachable from local Iran — schema changes go
# through the Neon SQL console; the production build runs on Vercel (US).

# --- Database (Neon Postgres) ---
# Pooled connection string (preferred for serverless).
POSTGRES_PRISMA_URL=
# Direct (non-pooled) connection — used for migrations / one-off scripts.
DATABASE_URL=

# --- Auth ---
# Random 32+ char secret. Generate: openssl rand -base64 32
SESSION_SECRET=

# --- Email (Resend) ---
RESEND_API_KEY=
# Where enrollment leads are emailed.
LEAD_NOTIFY_EMAIL=

# --- Vercel Blob (image uploads) ---
BLOB_READ_WRITE_TOKEN=

# --- Upstash (rate limiting the public form) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Zarinpal (paid course checkout) ---
# Leave empty to keep online checkout disabled (buy page shows "coming soon").
# Merchant id (UUID) from your Zarinpal panel.
ZARINPAL_MERCHANT_ID=
# Set to 1 to use the Zarinpal SANDBOX endpoints for test payments.
ZARINPAL_SANDBOX=
